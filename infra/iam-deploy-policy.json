{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SyncBuildToBucket",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME",
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/*"
      ]
    },
    {
      "Sid": "InvalidateCloudFrontCache",
      "Effect": "Allow",
      "Action": ["cloudfront:CreateInvalidation"],
      "Resource": "arn:aws:cloudfront::REPLACE_WITH_ACCOUNT_ID:distribution/REPLACE_WITH_DISTRIBUTION_ID"
    }
  ]
}
